{
  "name": "@roles/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "clean": "rimraf dist",
    "build": "pnpm run clean && tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "test": "tsx --test test/*.test.ts test/**/*.test.ts",
    "lint": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.test.json"
  },
  "dependencies": {
    "@clerk/express": "^1.7.58",
    "cors": "2.8.5",
    "dotenv": "16.5.0",
    "express": "5.2.1",
    "helmet": "7.1.0",
    "mammoth": "1.9.1",
    "mongoose": "9.7.4",
    "multer": "2.0.2",
    "pdf-parse": "1.1.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/cors": "2.8.17",
    "@types/express": "5.0.0",
    "@types/multer": "1.4.12",
    "@types/node": "22.12.0",
    "@types/pdf-parse": "1.1.5",
    "@types/supertest": "^7.2.0",
    "rimraf": "^6.1.3",
    "supertest": "^7.2.2",
    "tsx": "4.19.2",
    "typescript": "5.8.3"
  }
}
